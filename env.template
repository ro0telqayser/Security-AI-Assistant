# Environment Configuration - Copy this template and create .env

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=False

# Security Tools Paths (for future Phase 3 implementation)
SEMGREP_PATH=semgrep
# HexStrike integration (preferred)
HEXSTRIKE_URL=http://127.0.0.1:4444
# HEXSTRIKE_API_KEY=change-me

# Backward compatibility (older local path-based setup)
HEXSTRIKE_PATH=../hexstrike-ai

# Scan safety
# Restrict scans to paths under this directory.
SCAN_ROOT=.

# DAST safety
# Restrict DAST scans to authorized targets (host allowlist). Default is local-only.
DAST_ALLOWLIST=localhost,127.0.0.1
# DAST_ALLOW_NONLOCAL=false

# AI / LLM (Ollama)
DEEPSEEK_MODEL=deepseek-r1:8b

# Database
DATABASE_URL=sqlite+aiosqlite:///./security_assistant.db

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
